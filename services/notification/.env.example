# Notification Service Environment Variables

# Server Configuration
PORT=3006
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hls_platform
DB_USER=postgres
DB_PASSWORD=password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=4

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email Templates
FROM_EMAIL=noreply@hlsplatform.com
FROM_NAME=HLS Platform

# Push Notification Configuration
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@hlsplatform.com

# WebSocket Configuration
WEBSOCKET_ENABLED=true

# Service URLs
USER_SERVICE_URL=http://localhost:3001

# Service Authentication
SERVICE_AUTH_TOKEN=development-service-token-change-in-production

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Notification Configuration
MAX_NOTIFICATIONS_PER_USER=1000
NOTIFICATION_RETENTION_DAYS=30
BATCH_SIZE=100

# Queue Configuration
EMAIL_QUEUE_CONCURRENCY=5
PUSH_QUEUE_CONCURRENCY=10
WEBSOCKET_QUEUE_CONCURRENCY=20

# Rate Limiting
EMAIL_RATE_LIMIT=50
PUSH_RATE_LIMIT=100

# Logging Configuration
LOG_LEVEL=info
