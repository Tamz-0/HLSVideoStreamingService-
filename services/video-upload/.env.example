# Video Upload Service Environment Variables

# Server Configuration
PORT=3002
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hls_platform
DB_USER=postgres
DB_PASSWORD=password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=hls-video-platform

# File Upload Configuration
MAX_FILE_SIZE=524288000  # 500MB in bytes
ALLOWED_VIDEO_TYPES=mp4,avi,mov,wmv,flv,webm,mkv,m4v,3gp,mpeg,mpg
ALLOWED_IMAGE_TYPES=jpeg,jpg,png,gif,webp

# Service URLs
USER_SERVICE_URL=http://localhost:3001
NOTIFICATION_SERVICE_URL=http://localhost:3006
METADATA_SERVICE_URL=http://localhost:3003

# Service Authentication
SERVICE_AUTH_TOKEN=development-service-token-change-in-production

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging Configuration
LOG_LEVEL=info

# Rate Limiting
UPLOAD_RATE_LIMIT=5
BULK_UPLOAD_RATE_LIMIT=2
THUMBNAIL_RATE_LIMIT=10
