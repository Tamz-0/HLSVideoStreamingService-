# Video Streaming Service Environment Variables

# Server Configuration
PORT=3005
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hls_platform
DB_USER=postgres
DB_PASSWORD=password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=3

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=hls-video-platform

# CDN Configuration
CDN_URL=https://your-cdn-domain.com
CDN_ENABLED=false

# Streaming Configuration
DEFAULT_QUALITY=720p
ADAPTIVE_STREAMING=true
BUFFER_SIZE=5242880  # 5MB
MAX_BITRATE=5000000  # 5Mbps

# Service URLs
USER_SERVICE_URL=http://localhost:3001
METADATA_SERVICE_URL=http://localhost:3003

# Service Authentication
SERVICE_AUTH_TOKEN=development-service-token-change-in-production

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Analytics Configuration
TRACK_VIEWS=true
TRACK_ENGAGEMENT=true
VIEW_THRESHOLD_SECONDS=30

# Cache Configuration
MANIFEST_CACHE_TTL=300
SEGMENT_CACHE_TTL=86400

# Logging Configuration
LOG_LEVEL=info
