# Environment Variables
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/hls_platform

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET=hls-video-storage

# CDN
CDN_URL=https://your-cloudfront-distribution.cloudfront.net

# File Upload
MAX_FILE_SIZE=2147483648  # 2GB in bytes
ALLOWED_VIDEO_TYPES=mp4,avi,mov,mkv,wmv

# Transcoding
TRANSCODING_QUEUE_CONCURRENCY=5
MAX_RETRY_ATTEMPTS=3

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3007

# Notification
WEBSOCKET_PORT=8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

# Security
CORS_ORIGIN=http://localhost:3000
SESSION_SECRET=your-session-secret-change-this
