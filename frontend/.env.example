# Environment variables for HLS Streaming Platform Frontend

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Authentication
NEXT_PUBLIC_JWT_STORAGE_KEY=hls_access_token
NEXT_PUBLIC_REFRESH_TOKEN_KEY=hls_refresh_token

# File Upload
NEXT_PUBLIC_MAX_FILE_SIZE=50000000
NEXT_PUBLIC_ALLOWED_VIDEO_TYPES=video/mp4,video/avi,video/mov,video/wmv
NEXT_PUBLIC_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Application
NEXT_PUBLIC_APP_NAME=HLS Streaming Platform
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Features
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true

# Development
NODE_ENV=development
