{
  "name": "hls-video-streaming-platform",
  "version": "1.0.0",
  "description": "A distributed HLS video streaming platform with microservices architecture",
  "main": "index.js",
  "scripts": {
    "start": "docker-compose up",
    "dev": "docker-compose up --build",
    "stop": "docker-compose down",
    "clean": "docker-compose down -v",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "eslint . --ext .js,.ts --fix"
  },
  "keywords": [
    "hls",
    "video",
    "streaming",
    "microservices",
    "nodejs",
    "ffmpeg",
    "docker",
    "kubernetes"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^18.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "nodemon": "^2.0.0",
    "prettier": "^2.0.0"
  },
  "dependencies": {
    "dotenv": "^16.0.0"
  }
}
